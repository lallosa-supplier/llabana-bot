#!/bin/bash
# 📊 Comando unificado para análisis diario de logs
# Uso: ./analyze-logs

set -e

echo "╔════════════════════════════════════════════════════════════════════════════════╗"
echo "║                     🔍 ANÁLISIS DIARIO DE LOGS                                ║"
echo "╚════════════════════════════════════════════════════════════════════════════════╝"
echo ""

# Colores
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${BLUE}[1/3]${NC} Generando análisis rápido (COMPLETE)..."
node src/analyze-logs-complete.js > /tmp/complete.txt 2>&1
echo -e "${GREEN}✓ Listo${NC}"
echo ""

echo -e "${BLUE}[2/3]${NC} Generando análisis detallado (DETAILED)..."
node src/analyze-logs-detailed.js > /tmp/detailed.txt 2>&1
echo -e "${GREEN}✓ Listo${NC}"
echo ""

# Extraer información clave
FECHA=$(date +%Y-%m-%d)
COMPLETE_FILE="daily-analysis/ANALYSIS-COMPLETE-${FECHA}.txt"
DETAILED_FILE="daily-analysis/ANALYSIS-DETAILED-${FECHA}.txt"

echo -e "${BLUE}[3/3]${NC} Resumiendo resultados..."
echo ""

# Mostrar resumen del COMPLETE
echo -e "${YELLOW}📋 RESUMEN RÁPIDO (ANALYSIS-COMPLETE)${NC}"
echo "─────────────────────────────────────────────────────────────────────────────────"
grep -A 20 "RESUMEN GENERAL" "$COMPLETE_FILE" | head -10
echo ""

# Mostrar resumen del DETAILED
echo -e "${YELLOW}📊 ANÁLISIS DETALLADO (ANALYSIS-DETAILED)${NC}"
echo "─────────────────────────────────────────────────────────────────────────────────"
grep -A 5 "RESUMEN FINAL DEL PERÍODO" "$DETAILED_FILE"
echo ""

# Mostrar punto de continuidad
echo -e "${YELLOW}🎯 PUNTO DE CONTINUIDAD PARA MAÑANA${NC}"
echo "─────────────────────────────────────────────────────────────────────────────────"
grep -A 8 "PRÓXIMO ANÁLISIS DEBE COMENZAR" "$DETAILED_FILE"
echo ""

echo -e "${GREEN}✅ ANÁLISIS COMPLETADO${NC}"
echo "─────────────────────────────────────────────────────────────────────────────────"
echo ""
echo -e "${BLUE}📁 Reportes generados:${NC}"
echo "  • ${COMPLETE_FILE}"
echo "  • ${DETAILED_FILE}"
echo ""
echo -e "${BLUE}📖 Para leer completo:${NC}"
echo "  cat ${DETAILED_FILE}"
echo ""
echo -e "${YELLOW}⚠️  BUSCA 🔴 PROBLEMAS DETECTADOS en el reporte DETAILED${NC}"
